<?xml version="1.0" encoding="utf-8"?>
<!-- 文件来源：暖橙琥珀（烛火） -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#B85A20"/><corners android:radius="13dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="#E87838" android:endColor="#F09450" android:angle="135"/>
                    <corners android:radius="13dp"/>
                    <stroke android:width="1dp" android:color="#FFC080"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#D08040"/><corners android:radius="13dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="#F09858" android:endColor="#F8B878" android:angle="135"/>
                    <corners android:radius="13dp"/>
                    <stroke android:width="0.5dp" android:color="#F0C090"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
