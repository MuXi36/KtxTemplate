<!-- RoundButton 风格：三层发光 Dock pill -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape><solid android:color="#E0C8A0"/><corners android:radius="28dp"/></shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
                <shape><solid android:color="#18E8A449"/><corners android:radius="28dp"/></shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape><solid android:color="#30F4A950"/><corners android:radius="28dp"/></shape>
            </item>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#8B5A20"/><corners android:radius="28dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="@color/sky_amber_dark" android:endColor="@color/sky_flame" android:angle="135"/>
                    <corners android:radius="28dp"/>
                    <stroke android:width="1.5dp" android:color="@color/sky_gold"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="4dp" android:bottom="4dp" android:left="4dp" android:right="4dp">
                <shape><solid android:color="#12E8A449"/><corners android:radius="28dp"/></shape>
            </item>
            <item android:top="2dp" android:bottom="2dp" android:left="2dp" android:right="2dp">
                <shape><solid android:color="#22F4A950"/><corners android:radius="28dp"/></shape>
            </item>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#C89040"/><corners android:radius="28dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="@color/sky_amber" android:endColor="@color/sky_gold" android:angle="135"/>
                    <corners android:radius="28dp"/>
                    <stroke android:width="1.5dp" android:color="@color/sky_amber_light"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>