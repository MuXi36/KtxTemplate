<!-- 光遇 · SpotlightCard 发光卡片（紧凑版） -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 外层发光环 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#18E8A449" />
            <corners android:radius="17dp" />
            <padding android:left="0.5dp" android:top="0.5dp" android:right="0.5dp" android:bottom="0.5dp" />
        </shape>
    </item>
    <!-- 中层渐变边框 -->
    <item>
        <shape android:shape="rectangle">
            <gradient android:type="linear" android:angle="135"
                android:startColor="#E8A449" android:centerColor="#F4A950" android:endColor="#7EC8E3" />
            <corners android:radius="16.5dp" />
            <padding android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp" />
        </shape>
    </item>
    <!-- 内层暖白底 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFF8EC" />
            <corners android:radius="15dp" />
            <padding android:left="12dp" android:top="10dp" android:right="12dp" android:bottom="10dp" />
        </shape>
    </item>
</layer-list>