<?xml version="1.0" encoding="utf-8"?>
<!-- 保存位置：选中高亮版（天蓝→白） -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#6090A8"/><corners android:radius="13dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="#80B8D0" android:endColor="#B0E0F0" android:angle="135"/>
                    <corners android:radius="13dp"/>
                    <stroke android:width="1dp" android:color="#E0F8FF"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#A0C8D8"/><corners android:radius="13dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="#D0E8F8" android:endColor="#E8F4FF" android:angle="135"/>
                    <corners android:radius="13dp"/>
                    <stroke android:width="0.5dp" android:color="#E0F0FF"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>