<!-- FitButton 风格：暖色渐变 + 边框 + 三角阴影 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#C8A870"/><corners android:radius="19dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <solid android:color="#E0C8A0"/>
                    <corners android:radius="19dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#8B5A20"/><corners android:radius="19dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="@color/sky_amber_dark" android:endColor="@color/sky_flame" android:angle="135"/>
                    <corners android:radius="19dp"/>
                    <stroke android:width="1dp" android:color="@color/sky_gold"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#C89040"/><corners android:radius="19dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="@color/sky_amber" android:endColor="@color/sky_gold" android:angle="135"/>
                    <corners android:radius="19dp"/>
                    <stroke android:width="1dp" android:color="@color/sky_amber_light"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>