<!-- FitButton 风格：边框 + 底色 + 微阴影 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#D8CCC0"/><corners android:radius="13dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <solid android:color="#E8DDD0"/>
                    <corners android:radius="13dp"/>
                    <stroke android:width="0.5dp" android:color="#C8B8A0"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="@color/sky_amber_dark"/><corners android:radius="13dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <solid android:color="@color/sky_cream_dark"/>
                    <corners android:radius="13dp"/>
                    <stroke android:width="1dp" android:color="@color/sky_amber"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#E0D4C0"/><corners android:radius="13dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <solid android:color="@color/sky_cream"/>
                    <corners android:radius="13dp"/>
                    <stroke android:width="0.5dp" android:color="@color/sky_amber_light"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>