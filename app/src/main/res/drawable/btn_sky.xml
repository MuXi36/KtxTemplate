<!-- FitButton 风格：冷色渐变 + 边框 + 阴影 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#A0B8C8"/><corners android:radius="19dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <solid android:color="#C0D8E8"/>
                    <corners android:radius="19dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#2A4050"/><corners android:radius="19dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="@color/sky_blue_dark" android:endColor="@color/sky_twilight" android:angle="135"/>
                    <corners android:radius="19dp"/>
                    <stroke android:width="1dp" android:color="@color/sky_blue"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#4A7088"/><corners android:radius="19dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="@color/sky_blue" android:endColor="@color/sky_blue_dark" android:angle="135"/>
                    <corners android:radius="19dp"/>
                    <stroke android:width="1dp" android:color="#C0E8FF"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>