<?xml version="1.0" encoding="utf-8"?>
<!-- 工具：选中高亮版（暮霭蓝→亮） -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#2A3850"/><corners android:radius="13dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="#6080B0" android:endColor="#80A0D0" android:angle="135"/>
                    <corners android:radius="13dp"/>
                    <stroke android:width="1dp" android:color="#A0C8F0"/>
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="2dp">
                <shape><solid android:color="#506488"/><corners android:radius="13dp"/></shape>
            </item>
            <item android:bottom="1dp">
                <shape>
                    <gradient android:startColor="#7898C0" android:endColor="#98B8E0" android:angle="135"/>
                    <corners android:radius="13dp"/>
                    <stroke android:width="0.5dp" android:color="#B0D0F0"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>