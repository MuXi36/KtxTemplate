<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.KtxConverter" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sky_amber</item>
        <item name="colorPrimaryDark">@color/sky_amber_dark</item>
        <item name="colorAccent">@color/sky_blue</item>
        <item name="android:colorBackground">@color/sky_cloud</item>
        <item name="android:statusBarColor">@color/sky_navy</item>
        <item name="android:navigationBarColor">@color/sky_cloud</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="alertDialogTheme">@style/SkyDialogTheme</item>
        <item name="materialAlertDialogTheme">@style/SkyDialogTheme</item>
    </style>

    <style name="Theme.KtxConverter" parent="Base.Theme.KtxConverter" />

    <style name="SkyDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:windowBackground">@drawable/dialog_bg</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/DialogBody</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogBtnPositive</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogBtnNegative</item>
        <item name="buttonBarNeutralButtonStyle">@style/DialogBtnNeutral</item>
    </style>

    <style name="DialogTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">#E8A449</item>
        <item name="android:textSize">17sp</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="DialogBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">#D0C8B8</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">3dp</item>
    </style>

    <style name="DialogBtnPositive" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">#E8A449</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="rippleColor">#20E8A449</item>
    </style>

    <style name="DialogBtnNegative" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">#908878</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="DialogBtnNeutral" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">#7EC8E3</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Dialog enter/exit animations need resource refs; remove to avoid compile issues -->
</resources>